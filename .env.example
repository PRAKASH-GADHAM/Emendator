# Database
POSTGRES_USER=codereviewer
POSTGRES_PASSWORD=your_password
POSTGRES_DB=codereviewer

DATABASE_URL=postgresql://codereviewer:your_password@localhost:5432/codereviewer

# JWT
JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_refresh_secret

# Server
NODE_ENV=development
PORT=5000

# Frontend
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:5000

# ─── OpenRouter Multi-Model AI Pipeline ─────────────────────────────────────
# Get your free API keys at https://openrouter.ai/
# Each model uses a separate key for independent rate-limit management.
OPENROUTER_API_KEY_GEMMA=sk-or-...
OPENROUTER_API_KEY_NEMOTRON=sk-or-...
OPENROUTER_API_KEY_GPTOSS=sk-or-...

# Per-model request timeout in milliseconds (default 60 s)
OPENROUTER_MODEL_TIMEOUT_MS=60000

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── GitHub OAuth ────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AI_RATE_LIMIT_WINDOW_MS=3600000
AI_RATE_LIMIT_MAX=20
